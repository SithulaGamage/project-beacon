RewriteEngine On
RewriteBase /

############################################
# 1. Allow social media + SEO crawlers
############################################

SetEnvIfNoCase User-Agent "facebookexternalhit" allow_ua
SetEnvIfNoCase User-Agent "Facebot" allow_ua
SetEnvIfNoCase User-Agent "LinkedInBot" allow_ua
SetEnvIfNoCase User-Agent "Twitterbot" allow_ua
SetEnvIfNoCase User-Agent "WhatsApp" allow_ua

<RequireAny>
  Require env allow_ua
  Require all granted
</RequireAny>

############################################
# 2. React Router (SPA routing fix)
############################################

# If file or directory exists, serve it normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise route everything to React
RewriteRule ^ index.html [L]

############################################
# 3. Security headers (optional but good SEO trust signal)
############################################

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>