RewriteEngine On
RewriteBase /

# -----------------------------
# Serve real files FIRST
# -----------------------------
RewriteCond %{REQUEST_URI} ^/sitemap\.xml$ [OR]
RewriteCond %{REQUEST_URI} ^/robots\.txt$
RewriteRule ^ - [L]

# -----------------------------
# React SPA fallback
# -----------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.html [L]